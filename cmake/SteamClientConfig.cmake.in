@PACKAGE_INIT@
include(CMakeFindDependencyMacro)
find_dependency(Boost OPTIONAL_COMPONENTS system)
if(NOT TARGET Boost::system)
    add_library(Boost::system ALIAS Boost::headers)
endif()
find_dependency(CURL REQUIRED)
find_dependency(SteamProtos REQUIRED)
find_dependency(cryptopp REQUIRED)
include("${CMAKE_CURRENT_LIST_DIR}/SteamClientTargets.cmake")